    "cloudflare-scraper": "^1.0.8",
    "dotenv": "^16.3.1",
    "puppeteer": "^24.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
