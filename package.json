{
  "name": "bithumb-announcement-bot",
  "version": "1.0.0",
  "description": "Bot de détection ultra-rapide de nouvelles annonces Bithumb",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
