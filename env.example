# Configuration du bot Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234567890abcdefghijklmnopqrstuvwxyz
TELEGRAM_CHAT_ID=-1001234567890

# Configuration du polling
POLL_MS=300
TARGET_URL=https://feed.bithumb.com/notice?category=9&page=1

# Configuration du proxy (optionnel)
USE_PROXY=false
PROXY_URL=https://your-worker.workers.dev

# Configuration du logging
LOG_LEVEL=info
LOG_FORMAT=json

# Configuration trading
LIVE_MODE=false
TRADING_BUDGET=0
LEVERAGE=1
STOP_LOSS_PERCENT=3
TAKE_PROFIT_PERCENT=0
MAX_HOLD_TIME_MS=180000
TIME_BEFORE_EXECUTION=0
QUOTE_CURRENCIES=USDT,USDC

# Exchange Bybit
ENABLE_BYBIT=true
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Exchange HyperLiquid
ENABLE_HYPERLIQUID=true
HYPERLIQUID_API_KEY=
HYPERLIQUID_API_SECRET=
HYPERLIQUID_PASSWORD=
